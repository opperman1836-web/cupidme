# ── CupidMe API — Production Environment Variables ──
# Copy this to .env and fill in real values

NODE_ENV=production
API_PORT=4000

# Frontend URL (set to your Vercel domain)
CORS_ORIGIN=https://cupidme.org,https://www.cupidme.org

# ── Supabase (from supabase.com dashboard → Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe (from stripe.com dashboard → Developers → API Keys) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Claude AI (from console.anthropic.com) ──
ANTHROPIC_API_KEY=sk-ant-...

# NOTE: No JWT_SECRET needed — auth uses Supabase JWTs exclusively.
# Token validation is handled by supabaseAdmin.auth.getUser(token).
