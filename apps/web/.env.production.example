# ── CupidMe Web — Production Environment Variables ──
# Set these in Vercel Dashboard → Settings → Environment Variables

# API URL (your Render/Railway backend URL)
NEXT_PUBLIC_API_URL=https://api.cupidme.org

# Supabase (same project, public keys only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Stripe publishable key (public, safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
